---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
    <div class="pdf-container">
        <iframe
            src="/cv.pdf#toolbar=0&navpanes=0&scrollbar=0"
            title="My CV"
            class="pdf-frame"
        >
        </iframe>
    </div>
</Layout>

<style>
    .pdf-container {
        width: 100vw;
        height: 100vh;
        overflow: hidden;
    }

    .pdf-frame {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
    }
</style>
